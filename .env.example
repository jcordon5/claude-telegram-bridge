# telegram-bridge config. Copy this file to `.env` (same folder; gitignored) and
# fill it in — or set these as OS environment variables. NEVER commit `.env`.

# From @BotFather (create a bot with /newbot):
TELEGRAM_BOT_TOKEN=

# Your chat id — discover it with:  python3 scripts/telegram.py chat-id
TELEGRAM_CHAT_ID=

# Allowlist: only these chat ids may reply to the bot. Defaults to
# TELEGRAM_CHAT_ID. Comma-separated to authorise more people.
TELEGRAM_ALLOWED_CHAT_IDS=

# Seconds a blocking `ask` waits for a reply before giving up (default 6h).
TELEGRAM_ASK_TIMEOUT=21600
